{
  "name": "zds-site",
  "version": "0.2.0",
  "description": "Site internet communautaire codé à l'aide du Framework Django 1.10",
  "directories": {
    "doc": "doc"
  },
  "engines": {
    "node": ">=8.0.0"
  },
  "scripts": {
    "lint": "eslint ./{assets,vite-src}/*.js ./vite.config.mjs",
